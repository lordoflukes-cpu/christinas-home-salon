# Site Configuration
NEXT_PUBLIC_SITE_URL=https://christinas-hair-and-care.co.uk

# Optional: Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Form submission service (Formspree, etc.)
# FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxx

# Optional: Google verification code for Search Console
# NEXT_PUBLIC_GOOGLE_VERIFICATION=your-verification-code

# --- Leo cloud sync (optional) ---------------------------------------------
# When BOTH are set, Leo syncs every entry & photo between phones via Supabase
# and requires the shared family sign-in. When unset, Leo runs fully on-device.
# Find these in Supabase: Settings (gear) -> API.
#   - Project URL  -> NEXT_PUBLIC_SUPABASE_URL
#   - anon public  -> NEXT_PUBLIC_SUPABASE_ANON_KEY   (safe to ship in the app)
# Never put the service_role secret key here.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Leo "Ask Leo" AI helper (optional) ------------------------------------
# Server-only Anthropic API key powering the Ask Leo screen (day summaries,
# doctor notes, family updates, etc.). Only logged TEXT is sent — never photos.
# When unset, the Ask Leo screen shows a graceful "not set up yet" state.
# Keep this server-side: NO NEXT_PUBLIC_ prefix, never expose it in the client.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Leo voice (optional) — ElevenLabs Jamaican-Patois TTS ------------------
# When BOTH are set, Leo can speak (reminders, AI answers, recaps). Off until set.
# Server-side only: NO NEXT_PUBLIC_ prefix, never expose in the client.
# Only the API key is required — the voice defaults to "Denzel" (Jamaican,
# raspy & deep). Set ELEVENLABS_VOICE_ID only to override the default voice.
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=dhwafD61uVd8h85wAZSE
# Optional: model — defaults to the rich eleven_multilingual_v2 (matches the
# Denzel preview). Set to eleven_flash_v2_5 for lower latency / lower richness.
# ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Leo push notifications (optional) -------------------------------------
# Public half of the VAPID key pair (safe to ship). The matching private key
# goes ONLY into the Supabase Edge Function secret (see docs/leo-cloud-sync.md).
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=BGqK5e6tm4urcn0-_wd5pR8QU4Cj0wgnBWGFlhS-qrlADwKKjZ4iF4KGJsZJTq2-swlRlVrshsnqsPpR_nS8V_E
