# Site Configuration
NEXT_PUBLIC_SITE_URL=https://christinas-hair-and-care.co.uk

# Optional: Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Form submission service (Formspree, etc.)
# FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxx

# Optional: Google verification code for Search Console
# NEXT_PUBLIC_GOOGLE_VERIFICATION=your-verification-code

# --- Leo cloud sync (optional) ---------------------------------------------
# When BOTH are set, Leo syncs every entry & photo between phones via Supabase
# and requires the shared family sign-in. When unset, Leo runs fully on-device.
# Find these in Supabase: Settings (gear) -> API.
#   - Project URL  -> NEXT_PUBLIC_SUPABASE_URL
#   - anon public  -> NEXT_PUBLIC_SUPABASE_ANON_KEY   (safe to ship in the app)
# Never put the service_role secret key here.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
